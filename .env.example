# Copy this file to .env and adjust values for your local setup.
# .env is git-ignored — never commit real credentials.
#
# Semantics:
# - Commented keys below are examples/documented defaults.
# - If you do not set a key in .env, the application uses the Python default from Settings.
# - Most keys below are runtime configuration and are NOT meant as experiment metadata.
# - Trace metadata for evaluation is controlled by sections marked "[traced]".
# - OpenTelemetry/Phoenix sections configure telemetry transport/runtime behavior,
#   not per-run evaluation metadata keys.
# - Optional [traced] keys are attached only when set.
# - `run_id` is always present (auto-generated unless EVAL_RUN_ID is set).

# --- Ollama (runtime config, not evaluation metadata) ---
# OLLAMA_BASE_URL=http://localhost:11434
# CHAT_MODEL=llama3.2
# EMBEDDING_MODEL=nomic-embed-text

# --- Qdrant (runtime config, not evaluation metadata) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=chatbot

# --- Corpus (runtime config, not evaluation metadata) ---
# CORPUS_PATH=corpus

# --- Retrieval (runtime config; summarized into traced retrieval_version) ---
# RETRIEVAL_TOP_K=5
# RETRIEVAL_SCORE_THRESHOLD=0.5

# --- Ingestion (runtime config, not evaluation metadata) ---
# EMBEDDING_DIM=768       # Must match the output dimension of EMBEDDING_MODEL
# SPLIT_LENGTH=200        # Words per chunk
# SPLIT_OVERLAP=20        # Word overlap between adjacent chunks

# --- Logging (runtime config, not evaluation metadata) ---
# LOG_FORMAT=console   # 'console' (dev) or 'json' (CI/prod)

# --- OpenTelemetry Tracing (runtime telemetry transport config) ---
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=chatbot
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
# OTEL_SAMPLE_RATE=1.0
# OTEL_CONSOLE_EXPORT=false

# --- Phoenix / OpenInference (runtime telemetry transport config) ---
# PHOENIX_PROJECT_NAME=chatbot-local          # Project shown in the Phoenix UI
# OTEL_DEPLOYMENT_ENVIRONMENT=development     # Attached as resource attribute to all spans
# OTEL_AUTO_INSTRUMENT_HAYSTACK=true          # Enable openinference-instrumentation-haystack

# --- Model Sampling [traced always] ---
# MODEL_TEMPERATURE=0.0                         # 0.0: most deterministic/focused, 1.0: more diverse/creative (less deterministic)
# MODEL_SEED=42                                 # Effective generation parameter and traced metadata

# --- Evaluation Metadata [traced] ---
# EVAL_ENVIRONMENT=local                        # Traced always
# EVAL_NAME=rag-prompt-tuning-2026-04           # Traced when set
# EVAL_RUN_ID=run-2026-04-29-a              # Optional override; otherwise auto-generated once per app process
# EVAL_CANDIDATE_ID=llama3.2__ans-7__cit-3__ret-1  # Traced when set
# EVAL_PROMPT_VERSION_ANSWER=answer_v7          # Traced when set
# EVAL_PROMPT_VERSION_CITATION=citation_v3      # Traced when set
# EVAL_RETRIEVAL_VERSION=ret_v1                 # Traced when set; if unset, trace metadata uses an auto label from RETRIEVAL_TOP_K and RETRIEVAL_SCORE_THRESHOLD
# EVAL_CORPUS_VERSION=corpus_2026-04-28         # Traced when set
# EVAL_DATASET_VERSION=dataset_2026-04-29       # Traced when set
