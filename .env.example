# Copy this file to .env and adjust values for your local setup.
# .env is git-ignored — never commit real credentials.
#
# Semantics:
# - Commented keys below are examples/documented defaults.
# - If you do not set a key in .env, the application uses the Python default from Settings.
# - Most keys below are runtime configuration and are NOT meant as experiment metadata.
# - Trace metadata for evaluation is controlled by sections marked "[traced]".
# - OpenTelemetry/Phoenix sections configure telemetry transport/runtime behavior,
#   not per-run evaluation metadata keys.
# - Optional [traced] keys are attached only when set.
# - `run_id` is always present (auto-generated unless EVAL_RUN_ID is set).

# --- Model providers (runtime config, not evaluation metadata) ---
# Default: both chat and embeddings run locally via Ollama.
# CHAT_MODEL_PROVIDER=ollama
# CHAT_BASE_URL=http://localhost:11434
# CHAT_MODEL=qwen3.5:9b
# CHAT_API_KEY=                               # Optional for ollama; required for openai_compatible
# -- try different models. qwen3.5:9b is a strong local default, while gpt-oss:120b-cloud
# -- may produce stronger citations if cloud usage is acceptable.
# CHAT_MODEL=gpt-oss:120b-cloud
#
# EMBEDDING_MODEL_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_MODEL=bge-m3

# --- OpenAI-compatible chat model provider (alternative to Ollama for chat) ---
# Set CHAT_MODEL_PROVIDER=openai_compatible to switch the chat model to any
# OpenAI-compatible endpoint (Groq, Together AI, Fireworks AI, …).
# EMBEDDING_MODEL_PROVIDER stays "ollama" — embeddings always run locally via EMBEDDING_BASE_URL.
#
# Example: Groq (free tier, Qwen3-32B at ~660 TPS)
# CHAT_MODEL_PROVIDER=openai_compatible
# CHAT_BASE_URL=https://api.groq.com/openai/v1
# CHAT_API_KEY=gsk_your_groq_api_key_here
# CHAT_MODEL=qwen/qwen3-32b
#
# Example: Together AI (pay-as-you-go, larger Qwen3 models available)
# CHAT_MODEL_PROVIDER=openai_compatible
# CHAT_BASE_URL=https://api.together.xyz/v1
# CHAT_API_KEY=your_togetherai_api_key_here
# CHAT_MODEL=Qwen/Qwen3-235B-A22B

# --- Qdrant (runtime config, not evaluation metadata) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=chatbot

# --- Corpus (runtime config, not evaluation metadata) ---
# CORPUS_PATH=corpus

# --- Retrieval (runtime config; summarized into traced retrieval_version) ---
# RETRIEVAL_TOP_K=5
# RETRIEVAL_LLM_TOP_K=10       # Optional: surface more candidates than top_k after RRF fusion; default=top_k

# --- Ingestion (runtime config, not evaluation metadata) ---
# EMBEDDING_DIM=1024      # Must match the output dimension of EMBEDDING_MODEL
# SPLIT_LENGTH=200        # Words per chunk
# SPLIT_OVERLAP=20        # Word overlap between adjacent chunks

# --- Vision / Multi-modal ingestion (runtime config, not evaluation metadata) ---
# VISION_INGESTION_ENABLED=true
# VISION_MODEL=qwen2.5vl:7b
# VISION_PROVIDER=ollama
# VISION_BASE_URL=http://localhost:11434
# IMAGE_CACHE_DIR=.cache/image_descriptions
# EXTRACTED_IMAGE_DIR=.cache/extracted_images
# IMAGE_MIN_DIMENSION=64
# IMAGE_MIN_DESCRIPTION_LENGTH=40

# --- Logging (runtime config, not evaluation metadata) ---
# LOG_FORMAT=console   # 'console' (dev) or 'json' (CI/prod)

# --- OpenTelemetry Tracing (runtime telemetry transport config) ---
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=chatbot
# OTEL_PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces
# OTEL_EXPORT_PHOENIX=true
# OTEL_EXPORT_JAEGER=true
# OTEL_JAEGER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SAMPLE_RATE=1.0
# OTEL_CONSOLE_EXPORT=false

# --- Phoenix / OpenInference (runtime telemetry transport config) ---
# PHOENIX_PROJECT_NAME=chatbot-local          # Project shown in the Phoenix UI
# OTEL_DEPLOYMENT_ENVIRONMENT=development     # Attached as resource attribute to all spans
# OTEL_AUTO_INSTRUMENT_HAYSTACK=true          # Enable openinference-instrumentation-haystack

# --- Model Sampling [traced always] ---
# MODEL_TEMPERATURE=0.0                         # 0.0: most deterministic/focused, 1.0: more diverse/creative (less deterministic)
# MODEL_SEED=42                                 # Effective generation parameter and traced metadata

# --- Evaluation Metadata [traced] ---
# EVAL_ENVIRONMENT=local                        # Traced always
# EVAL_NAME=rag-prompt-tuning-2026-04           # Traced when set
# EVAL_RUN_ID=run-2026-04-29-a              # Optional override; otherwise auto-generated once per app process
# EVAL_CANDIDATE_ID=llama3.2__ans-7__cit-3__ret-1  # Traced when set
# EVAL_PROMPT_VERSION_ANSWER=answer_v7          # Traced when set
# EVAL_PROMPT_VERSION_CITATION=citation_v3      # Traced when set
# EVAL_RETRIEVAL_VERSION=ret_v1                 # Traced when set
# EVAL_CORPUS_VERSION=corpus_2026-04-28         # Traced when set
# EVAL_DATASET_VERSION=dataset_2026-04-29       # Traced when set

# --- Evaluation LLM Judge (used by eval/run_experiment.py for LLM-based evaluators) ---
# Recommended: Llama 3.3 70B via Fireworks AI or Groq — strong reasoning, handles large
# faithfulness-evaluation prompts, low cost. Local Ollama works too but is slower.
# For ollama, set EVAL_JUDGE_BASE_URL to the bare Ollama server URL (without /v1).
# The /v1 path suffix is appended automatically by run_experiment.py.
# EVAL_JUDGE_API_KEY=                           # Required for openai_compatible only
#
# Example: Fireworks AI (pay-as-you-go)
# EVAL_JUDGE_PROVIDER=openai_compatible
# EVAL_JUDGE_BASE_URL=https://api.fireworks.ai/inference/v1
# EVAL_JUDGE_API_KEY=fw_your_fireworks_api_key_here
# EVAL_JUDGE_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
#
# Example: Groq (free tier available)
# Note: free-tier models have low TPM limits — use a model with higher context allowance.
# EVAL_JUDGE_PROVIDER=openai_compatible
# EVAL_JUDGE_BASE_URL=https://api.groq.com/openai/v1
# EVAL_JUDGE_API_KEY=gsk_your_groq_api_key_here
# EVAL_JUDGE_MODEL=llama-3.3-70b-versatile
#
# Example: local Ollama
# EVAL_JUDGE_PROVIDER=ollama
# EVAL_JUDGE_BASE_URL=http://localhost:11434
# EVAL_JUDGE_MODEL=llama3.1:8b
# EVAL_JUDGE_INITIAL_PER_SECOND_REQUEST_RATE=1.5
